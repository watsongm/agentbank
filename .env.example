# agentBANK environment variables
# Copy this file to .env and fill in your values

# Base URL of the agentBANK API
# Default: http://localhost:3000 (for local development)
AGENTBANK_BASE_URL=http://localhost:3000

# Bearer token for authentication
# Obtain via the FAPI OAuth 2.0 PAR flow, or use "demo-token" for local development
AGENTBANK_TOKEN=demo-token
