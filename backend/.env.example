# agentBANK backend — reference implementation
# Copy to .env and fill in for local dev (docker-compose sets these automatically)

# HTTP
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database — Postgres
DATABASE_URL=postgresql://agentbank:agentbank@localhost:5432/agentbank?schema=public

# Auth (tier 2 — stubs today)
JWT_SECRET=change-me-in-prod-this-is-a-reference-only
AUTH_ISSUER=http://localhost:3000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentbank-backend

# Demo toggles
DEMO_MODE=true
SEED_ON_START=true
